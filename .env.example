APP_NAME=Fandrio
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Base de données (PostgreSQL) ─────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fandrio
DB_USERNAME=fandrio
DB_PASSWORD=secret

# ── Authentification JWT ─────────────────────────────────────────
JWT_SECRET=

# ── Clé API (header X-API-KEY) ───────────────────────────────────
API_KEY=

# ── Broadcasting / Reverb (WebSockets) ──────────────────────────
BROADCAST_DRIVER=reverb

REVERB_APP_ID=fandrio-local
REVERB_APP_KEY=fandrio-key
REVERB_APP_SECRET=fandrio-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# ── Cloudinary (upload logos compagnies) ─────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Cache / Queue / Session ──────────────────────────────────────
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Docker Compose (ports exposés sur l'hôte) ───────────────────
# APP_PORT=8000
# DB_PORT_FORWARD=5432
# REVERB_PORT_FORWARD=8080
# PGADMIN_PORT=5050
# PGADMIN_EMAIL=admin@fandrio.mg
# PGADMIN_PASSWORD=admin
